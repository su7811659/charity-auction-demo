# ── 後端環境變數範本 ──
# 複製成 backend/.env 後填入。Demo 不填任何值也能直接啟動。

# 留空 = Demo 模式：AI 功能改用示範回應，不呼叫 OpenAI、不產生任何費用。
# 要啟用真實 AI，填入 sk-... 開頭的金鑰。
OPENAI_API_KEY=

# 管理員後台 token（demo 預設 demo-admin；正式部署請改成強密碼）
ADMIN_SECRET=demo-admin

# 伺服器設定（本機開發可省略，使用預設值）
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 選用：圖片上傳到 Cloudinary（未設定則自動改存本機 /uploads）
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 選用：回饋信箱寫入 Google Sheet 時才需要（另需放置 google_credentials.json）
GOOGLE_SPREADSHEET_ID=
