{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://bidforgood-api.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://bidforgood-api.onrender.com/uploads/:path*" }
  ]
}
